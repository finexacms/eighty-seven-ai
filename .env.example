# ============================================
# Eighty Seven AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# For Vercel: Add these in Project Settings → Environment Variables

# --- Z.ai SDK (Required) ---
# Get your API key from: https://z.ai
ZAI_BASE_URL=https://external-api.z.ai/v1
ZAI_API_KEY=your_zai_api_key_here

# --- Database (Required for Vercel) ---
# Option 1: Vercel Postgres (recommended)
#   Create at: https://vercel.com/dashboard/stores
#   Format: postgres://user:password@host:5432/database?sslmode=require
#
# Option 2: Supabase (free tier)
#   Create at: https://supabase.com
#   Format: postgresql://postgres:password@db.project.supabase.co:5432/postgres
DATABASE_URL=your_postgresql_connection_string_here

# --- NextAuth (if using authentication) ---
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://your-domain.vercel.app
